{
	"version": 2,
	"builds": [
		{
			"src": "src/api/index.js",
			"use": "@vercel/node"
		}
	],
	"routes": [
		{
			"src": "/",
			"status": 302,
			"headers": { "Location": "/api/v1/documentation/swagger" }
		},
		{
			"src": "/(.*)",
			"dest": "src/api/index.js"
		}
	],
	"functions": {
		"src/api/index.js": {
			"includeFiles": ["swagger.json"]
		}
	}
}
