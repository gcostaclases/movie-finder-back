{
	"name": "pelis-y-series-api",
	"version": "1.0.0",
	"main": "src/api/index.js",
	"type": "module",
	"author": "Guillermina Costa",
	"description": "**API RESTful de películas y series** desarrollada con **Node.js**, **Express** y **MongoDB**.  \r Permite buscar películas y series, puntuarlas, reseñarlas y ver en que servicio de streaming se encuentran, entre otras cosas.",
	"license": "ISC",
	"keywords": [
		"api",
		"movies",
		"series",
		"express",
		"mongodb"
	],
	"scripts": {
		"dev": "nodemon api/dev.js",
		"start": "node api/index.js",
		"prod": "cross-env NODE_ENV=production nodemon api/dev.js",
		"import:movies": "node src/scripts/importPopularMovies.js",
		"import:movies:prod": "cross-env NODE_ENV=production node src/scripts/importPopularMovies.js"
	},
	"dependencies": {
		"@sentry/node": "^10.18.0",
		"@upstash/redis": "^1.35.4",
		"axios": "^1.12.2",
		"bcrypt": "^6.0.0",
		"cors": "^2.8.5",
		"express": "^5.1.0",
		"express-rate-limit": "^8.1.0",
		"joi": "^18.0.1",
		"jsonwebtoken": "^9.0.2",
		"mongoose": "^8.18.1",
		"morgan": "^1.10.1",
		"node-cache": "^5.1.2",
		"swagger-ui-express": "^5.0.1"
	},
	"devDependencies": {
		"cross-env": "^10.1.0",
		"dotenv": "^17.2.2",
		"nodemon": "^3.1.10"
	}
}
