###############################################
# USER PROVIDERS (Autenticado)
###############################################

### Get my providers
GET {{host}}/me/providers HTTP/1.1
Authorization: Bearer {{tokenClient}}

### Add provider to my list
POST {{host}}/me/providers HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{tokenClient}}

{
  "providerId": "{{providerDisneyId}}"
}

### Remove provider from my list
DELETE {{host}}/me/providers/{{providerDisneyId}} HTTP/1.1
Authorization: Bearer {{tokenClient}}

###############################################
# MOVIES
###############################################

### Get all movies
GET {{host}}/movies HTTP/1.1
Authorization: Bearer {{tokenClient}}

### Get movies by title (filter)
GET {{host}}/movies?title=Superman HTTP/1.1
Authorization: Bearer {{tokenClient}}

###############################################
# WATCHLIST (Autenticado)
###############################################

### Get my watchlist
GET {{host}}/me/watchlist HTTP/1.1
Authorization: Bearer {{tokenClient}}

### Add movie to watchlist - Superman
POST {{host}}/me/watchlist HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{tokenClient}}

{
  "movieId": "{{movieSupermanId}}"
}

### Add movie to watchlist - F1
POST {{host}}/me/watchlist HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{tokenClient}}

{
  "movieId": "{{movieF1Id}}"
}

### Remove movie from watchlist
DELETE {{host}}/me/watchlist/{{movieSupermanId}} HTTP/1.1
Authorization: Bearer {{tokenClient}}

###############################################
# REVIEWS (Público)
###############################################

### Get reviews of a movie
GET {{host}}/reviews/movies/{{movieSupermanId}} HTTP/1.1

###############################################
# REVIEWS (Autenticado)
###############################################

### Create review - Superman
POST {{host}}/reviews HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{tokenClient}}

{
  "movieId": "{{movieSupermanId}}",
  "rating": 9,
  "comment": "Excelente película, un clásico imperdible de superhéroes."
}

### Create review - F1
POST {{host}}/reviews HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{tokenClient}}

{
  "movieId": "{{movieF1Id}}",
  "rating": 8,
  "comment": "Gran documental sobre la Fórmula 1, muy emocionante."
}

### Get my reviews
GET {{host}}/reviews/me HTTP/1.1
Authorization: Bearer {{tokenClient}}

### Update my review
PATCH {{host}}/reviews/{{reviewId}} HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{tokenClient}}

{
  "rating": 10,
  "comment": "La mejor película de superhéroes. Obra maestra absoluta."
}

### Delete my review
DELETE {{host}}/reviews/{{reviewId}} HTTP/1.1
Authorization: Bearer {{tokenClient}}