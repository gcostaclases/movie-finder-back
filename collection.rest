###############################################
# REVIEWS (Autenticado)
###############################################

### Create review - Superman (sin availability)
POST {{host}}/reviews HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{tokenClient}}

{
  "movieId": "{{movieSupermanId}}",
  "rating": 9,
  "comment": "Excelente película, un clásico imperdible de superhéroes."
}

### Create review - Superman (CON availability - híbrido)
POST {{host}}/reviews HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{tokenClient}}

{
  "movieId": "{{movieSupermanId}}",
  "rating": 9,
  "comment": "Excelente película, un clásico imperdible de superhéroes.",
  "providerId": "{{providerNetflixId}}"
}

### Create review - Los Cuatro Fantásticos
POST {{host}}/reviews HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{tokenClient}}

{
  "movieId": "{{movieCuatroFantasticos}}",
  "rating": 8,
  "comment": "Gran película de superhéroes, muy entretenida."
}

### Get my reviews
GET {{host}}/reviews/me HTTP/1.1
Authorization: Bearer {{tokenClient}}

### Update my review
PATCH {{host}}/reviews/{{reviewId}} HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{tokenClient}}

{
  "rating": 10,
  "comment": "La mejor película de superhéroes. Obra maestra absoluta."
}

### Delete my review
DELETE {{host}}/reviews/{{reviewId}} HTTP/1.1
Authorization: Bearer {{tokenClient}}